# Copy to .env, fill in what you use, then `source .env` before running.
# The sotellme CLI reads plain environment variables; nothing auto-loads this
# file, so it must be sourced (or the vars exported some other way).

# LLM provider: anthropic | openai | google_genai
export SOTELLME_PROVIDER=anthropic

# API key for the provider you picked (only that one is required)
export ANTHROPIC_API_KEY=
# export OPENAI_API_KEY=
# export GOOGLE_API_KEY=

# Optional per-slot model overrides (defaults come from the provider)
# export SOTELLME_FAST_MODEL=
# export SOTELLME_SMART_MODEL=

# Optional: where sessions/checkpoints are stored (default ~/.sotellme)
# export SOTELLME_DATA_DIR=

# Optional dev-time tracing; tool runs identically without these
# export LANGFUSE_PUBLIC_KEY=
# export LANGFUSE_SECRET_KEY=
# export LANGFUSE_HOST=
